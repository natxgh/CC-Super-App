# คัดลอกเป็น .env แล้วเติมค่า (ไฟล์ .env ถูก gitignore — ห้าม commit รหัสจริง)
#
# ⚠️ env จริงสำหรับเทสต้องเป็น QA ไม่ใช่ STG
# URL STG ด้านล่างเป็น placeholder อ้างอิง — เมื่อได้ env QA แล้วเปลี่ยน CC_BASE_URL เป็น URL QA
# ตราบใดที่ยังไม่ตั้ง CC_BASE_URL → เทส UI/validation จะถูก skip (ไม่ยิงไป STG)
# ตราบใดที่ยังไม่ตั้ง CC_PASSWORD → เทสที่ต้อง auth จริงจะถูก skip
CC_BASE_URL=
CC_ENV_TAG=QA

# Real Example test data จาก test design (บัญชีสมมติ — ใช้เมื่อ env รองรับ)
CC_ORG=BMA
CC_USERNAME=somchai.jai
CC_PASSWORD=
