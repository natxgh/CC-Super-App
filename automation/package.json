{
  "name": "cc-customer-profile-automation",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright E2E for CC Super App — Customer Profile (generated from customer-profile-testcases.xlsx)",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "list": "playwright test --list",
    "report": "playwright show-report",
    "capture": "playwright test || true; echo 'run finished — see playwright-report/ + test-results/steps'",
    "cards": "node scripts/gen-bug-cards.mjs",
    "teardown": "CP_TEARDOWN=1 node tests/customer-profile/teardown/global-teardown.ts",
    "test:product": "PIM_TEARDOWN=1 playwright test tests/product-inventory",
    "teardown:product": "PIM_TEARDOWN=1 playwright test tests/product-inventory --grep __never_match__",
    "test:linkage": "CP_TEARDOWN=1 playwright test tests/linkage-customer-case",
    "teardown:linkage": "CP_TEARDOWN=1 playwright test tests/linkage-customer-case --grep __never_match__",
    "test:formconfig": "CFC_TEARDOWN=1 playwright test tests/customer-form-configuration",
    "teardown:formconfig": "CFC_TEARDOWN=1 playwright test tests/customer-form-configuration --grep __never_match__"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  }
}
