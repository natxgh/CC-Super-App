# คัดลอกเป็น .env แล้วเติมค่า (.env ถูก gitignore — ห้าม commit รหัสจริง)

# ---- UI (Playwright) ----
CP_BASE_URL=https://skyai-cloud-cc-qa.one-sky.ai
CP_ORG=
CP_USERNAME=ketwadee
# ใส่รหัสบัญชี ketwadee เพื่อรันเทสกลุ่มที่ต้องล็อกอินจริง (ส่วนใหญ่ของ spec นี้)
CP_PASSWORD=

# ---- API-First Arrange + Teardown ----
# base URL ของ REST API (ใช้ seed Customer ก่อนเทส + DELETE ตอน teardown)
CP_API_BASE=
# token/credential สำหรับยิง API (ถ้าใช้ Bearer)
CP_API_TOKEN=
# เปิด globalTeardown (API DELETE) — set =1 เพื่อให้ลบ customer ที่ seed หลังรันจบ
CP_TEARDOWN=
